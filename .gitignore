# .vscode/mcp.json — tracked: no secrets, safe to commit
.gemini/settings.json

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Node
node_modules/
package-lock.json

# Media (raw and exports can be large)
media/raw/
media/exports/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
*.swp
*.swo

# Google Ads config (contains credentials)
google-ads.yaml

# Session archives (can get large)
memory/ARCHIVES/*.gz

# Email blast — recipient lists and send logs contain PII
data/email_lists/*.csv
!data/email_lists/sample_recipients.csv
data/email_logs/
