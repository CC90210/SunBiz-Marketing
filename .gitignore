# Credentials
.env.agents
.env
.env.local
.long_lived_token.txt

# Playwright MCP data
.playwright-mcp/

# Cache and audit data
data/cache/
data/audit/

# MCP configs (credentials are read from .env.agents at runtime, not stored here)
